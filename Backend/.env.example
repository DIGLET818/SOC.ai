# Copy this file to .env and fill in your values. Do not commit .env.

# Jira (for Create in Jira on Jira Tickets page)
JIRA_BASE_URL=https://policybazaarjira.atlassian.net
JIRA_EMAIL=it-so@policybazaar.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT_KEY=SOC
JIRA_ISSUE_TYPE=Task
# Optional: if Jira returns 400, set the issue type id (e.g. from project settings): JIRA_ISSUE_TYPE_ID=10001
